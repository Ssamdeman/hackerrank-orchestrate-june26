# Copy to code/.env (git-ignored) and fill in. Secrets are read from the
# environment only — never hardcoded, never committed.
# NOTE: this file (.env.example) IS committed — keep only placeholders here.

# --- Provider selection ---------------------------------------------------
# Which vision provider Stage 1 uses: anthropic | openrouter
VISION_PROVIDER=anthropic

# --- Keys (put real values in code/.env, not here) ------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...

# --- Optional Stage 1 (vision) overrides ----------------------------------
# VISION_MODEL=                       # overrides the per-provider default.
#                                     #   anthropic default:  claude-opus-4-8
#                                     #   openrouter default: nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# VISION_MAX_TOKENS=1024              # openrouter floors this at 2048 (reasoning model needs room)
# VISION_TEMPERATURE=                 # empty = omit on Anthropic (Opus 4.8 400s on it);
#                                     # OpenRouter defaults to 0 for determinism.
# VISION_SEED=0                       # OpenRouter determinism seed.
